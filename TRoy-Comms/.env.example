# ============================================================
#  TRoyTel™ — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to GitHub.
# ============================================================

# --- Server ---
PORT=3500
NODE_ENV=development
SERVER_URL=http://localhost:3500

# --- Twilio SMS (Free Trial: $15 credit) ---
# Sign up: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- TextBelt SMS (Free: 1/day per IP for testing) ---
# API key "textbelt" is the free key
TEXTBELT_API_KEY=textbelt

# --- SIP / Asterisk ---
# Your SIP provider credentials (sip2sip.info is FREE)
SIP_DOMAIN=sip2sip.info
SIP_USER_MARITIME=maritime
SIP_USER_TRAVEL=travel
SIP_USER_TRADING=trading
SIP_PASSWORD_MARITIME=changeme
SIP_PASSWORD_TRAVEL=changeme
SIP_PASSWORD_TRADING=changeme

# --- Jitsi ---
# Use public Jitsi (meet.jit.si) = FREE
# Or self-host your own Jitsi server
JITSI_DOMAIN=meet.jit.si
JITSI_APP_ID=troygroupcomms
# JWT secret only needed for self-hosted Jitsi with auth
# JITSI_APP_SECRET=your_secret_here

# --- Matrix / Synapse (self-hosted messaging) ---
MATRIX_HOMESERVER_URL=https://matrix.org
MATRIX_ACCESS_TOKEN=your_matrix_token

# --- Security ---
# Random secret for session/signaling auth
SIGNALING_SECRET=change_this_to_a_random_secret_string

# --- Allowed origins for CORS ---
CORS_ORIGINS=http://localhost:3500,https://troytel-signaling.onrender.com,https://troygroup.com,https://troygo.com
